{
  "info": {
    "name": "Fawry Payment Routing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "fawry-payment-routing"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (biller1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.accessToken) {",
                  "  pm.environment.set('accessToken', response.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"biller1\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.accessToken) {",
                  "  pm.environment.set('accessToken', response.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"new_biller\",\n  \"password\": \"StrongPassword1!\",\n  \"role\": \"BILLER\",\n  \"billerCode\": \"BILL_67890\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        }
      ]
    },
    {
      "name": "Gateways",
      "item": [
        {
          "name": "List Gateways",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/gateways", "host": ["{{baseUrl}}"], "path": ["gateways"] }
          }
        },
        {
          "name": "Create Gateway",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"GW4\",\n  \"name\": \"Gateway 4\",\n  \"fixedFee\": 1.50,\n  \"percentageFee\": 0.0200,\n  \"dailyLimit\": 75000.00,\n  \"minTransaction\": 20.00,\n  \"maxTransaction\": 7500.00,\n  \"processingTimeMinutes\": 60,\n  \"available24x7\": true,\n  \"active\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/gateways", "host": ["{{baseUrl}}"], "path": ["gateways"] }
          }
        },
        {
          "name": "Update Gateway",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"GW1\",\n  \"name\": \"Gateway 1 — updated\",\n  \"fixedFee\": 2.00,\n  \"percentageFee\": 0.0150,\n  \"dailyLimit\": 60000.00,\n  \"minTransaction\": 10.00,\n  \"maxTransaction\": 5000.00,\n  \"processingTimeMinutes\": 0,\n  \"available24x7\": true,\n  \"active\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/gateways/1", "host": ["{{baseUrl}}"], "path": ["gateways", "1"] }
          }
        },
        {
          "name": "Delete Gateway",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/gateways/4", "host": ["{{baseUrl}}"], "path": ["gateways", "4"] }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Recommend — Instant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billerId\": \"BILL_12345\",\n  \"amount\": 1000,\n  \"urgency\": \"INSTANT\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/payments/recommend", "host": ["{{baseUrl}}"], "path": ["payments", "recommend"] }
          }
        },
        {
          "name": "Recommend — Can wait",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billerId\": \"BILL_12345\",\n  \"amount\": 8000,\n  \"urgency\": \"CAN_WAIT\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/payments/recommend", "host": ["{{baseUrl}}"], "path": ["payments", "recommend"] }
          }
        },
        {
          "name": "Split Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billerId\": \"BILL_12345\",\n  \"amount\": 12000,\n  \"urgency\": \"INSTANT\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/payments/split", "host": ["{{baseUrl}}"], "path": ["payments", "split"] }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Biller History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/billers/BILL_12345/transactions?date={{today}}",
              "host": ["{{baseUrl}}"],
              "path": ["billers", "BILL_12345", "transactions"],
              "query": [{ "key": "date", "value": "{{today}}" }]
            }
          }
        }
      ]
    }
  ]
}
